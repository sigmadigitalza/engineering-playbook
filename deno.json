{
  "version": "0.2.0",
  "description": "Sigma Digital engineering playbook — static docs site built with Lume.",
  "imports": {
    "lume/": "https://deno.land/x/lume@v3.2.4/"
  },
  "tasks": {
    "lume": "echo \"import 'lume/cli.ts'\" | deno run -A -",
    "build": "deno task lume",
    "serve": "deno task lume -s",
    "clean": "rm -rf dist dist.tar.gz",
    "package": "deno task build && tar -czf dist.tar.gz -C dist .",
    "build:skills": "deno run --allow-read --allow-write scripts/build-skills.ts",
    "build:skills:check": "deno run --allow-read scripts/build-skills.ts --check",
    "release:version": "deno run -A jsr:@sigmadigitalza/rational-release@^1 read-version deno.json"
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ]
  },
  "lock": false,
  "fmt": {
    "include": [
      "_config.ts",
      "_data.json",
      "deno.json",
      "scripts/"
    ]
  }
}
