<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ if title }}{{ title }} — {{ /if }}{{ site.title }}</title>
  <meta name="description" content="{{ description || site.subtitle }}">
  <meta name="color-scheme" content="light dark">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <header class="site-header">
    <div class="wrap">
      <a href="/" class="brand">{{ site.title }}</a>
      <nav class="primary" aria-label="Primary">
        <a href="/#playbooks">Playbooks</a>
        <a href="/#prompts">Prompts</a>
        <a href="https://github.com/sigmadigitalza/engineering-playbook" rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <main id="main" class="wrap">
    {{ content |> safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>
        Maintained by <a href="https://sigmadigital.io" rel="noopener">Sigma Digital</a>.
        Source on <a href="https://github.com/sigmadigitalza/engineering-playbook" rel="noopener">GitHub</a>.
      </p>
    </div>
  </footer>
</body>
</html>
