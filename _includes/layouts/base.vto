<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ if title }}{{ title }} — {{ /if }}{{ site.title }}</title>
  <meta name="description" content="{{ description || site.subtitle }}">
  <meta name="color-scheme" content="light dark">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,600&family=Hanken+Grotesk:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css?v={{ cssVersion }}">
  <script src="/copy.js" defer></script>
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <header class="site-header">
    <div class="wrap">
      <a href="/" class="brand">Sigma&nbsp;<span>Playbook</span></a>
      <nav class="primary" aria-label="Primary">
        <a href="/docs/standards/">Engineering</a>
        <a href="/docs/design/">Design</a>
        <a href="/docs/playbooks/">Playbooks</a>
        <a href="https://github.com/sigmadigitalza/engineering-playbook" rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <main id="main" class="wrap">
    {{ content |> safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="foot-top">
        <span class="foot-label">{{ site.title }}</span>
        <p class="colophon">One language for how we build, design, and ship.</p>
      </div>
      <nav class="foot-nav" aria-label="Sections">
        <a href="/docs/standards/">Engineering</a>
        <a href="/docs/design/">Design</a>
        <a href="/docs/playbooks/">Playbooks &amp; Prompts</a>
        <a href="https://github.com/sigmadigitalza/engineering-playbook" rel="noopener">GitHub</a>
      </nav>
    </div>
  </footer>
</body>
</html>
